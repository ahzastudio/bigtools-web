                        <img src="/assets/img/screenshot_arcmap.png"
                            class="w-full h-64 object-cover object-top group-hover:scale-105 transition duration-500 cursor-zoom-in"
                            alt="ArcMap Toolbox" onclick="openLightbox(this.src)">
                        <div class="p-4 bg-slate-800">
                            <h4 class="font-bold text-center">Tampilan Toolbox (ArcMap)</h4>
                        </div>
                    </div>
                    <div
                        class="rounded-xl overflow-hidden shadow-2xl border border-slate-700 group cursor-pointer hover:border-purple-500 transition">
