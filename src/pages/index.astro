---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BIG Downloader Toolbox - Download Peta Indonesia Sekali Klik">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden">
        <!-- Background Glow -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-emerald-500/20 blur-[120px] rounded-full pointer-events-none">
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
            <span
                class="inline-block py-1 px-3 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-semibold tracking-wide uppercase mb-6 animate-pulse">
                v2.0 • QGIS, ArcGIS Pro & ArcMap
            </span>
            <img src="/assets/img/logo.png" alt="Big Downloader Logo"
                class="w-32 h-32 mx-auto mb-8 drop-shadow-2xl animate-bounce-slow">
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
                Download Peta Indonesia<br>
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-cyan-400">Tanpa Ribet,
                    Sekali Klik.</span>
            </h1>
            <p class="mt-4 max-w-2xl mx-auto text-xl text-slate-400 mb-10">
                Solusi All-in-One untuk kebutuhan data geospasial. Tersedia untuk <b>QGIS</b>, <b>ArcGIS Pro</b>, dan
                <b>ArcMap</b>. Download Peta RBI, DEMNAS, dan BATNAS secara massal & otomatis.
            </p>
            <div class="flex justify-center gap-4">
                <a href="#download"
                    class="px-8 py-4 bg-emerald-500 hover:bg-emerald-600 rounded-lg text-lg font-bold transition shadow-xl shadow-emerald-500/20 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Download Tools
                </a>
                <a href="https://wa.me/6282254760769" target="_blank"
                    class="px-8 py-4 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-lg text-lg font-medium transition">
                    Hubungi Developer
                </a>
            </div>

            <!-- Hero Screenshot -->
            <div class="mt-16 rounded-xl overflow-hidden shadow-2xl border border-slate-700/50 max-w-4xl mx-auto">
                <img src="/assets/img/screenshot_demnas.png" alt="Demo DEMNAS" class="w-full">
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section id="features" class="py-20 bg-slate-900/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold mb-4">Fitur Unggulan</h2>
                <p class="text-slate-400">Satu Toolbox untuk semua platform GIS favorit Anda.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Feature 1 -->
                <div
                    class="p-8 rounded-2xl glass hover:bg-slate-800/50 transition duration-300 border-t border-emerald-500/20 text-center group">
                    <div
                        class="w-20 h-20 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 mx-auto group-hover:scale-110 transition">
                        <img src="/assets/img/icon_rbi.png" alt="RBI Icon" class="w-12 h-12">
                    </div>
                    <h3 class="text-xl font-bold mb-3">Multi-Platform</h3>
                    <p class="text-slate-400">Mendukung QGIS 3.x, ArcGIS Pro (PYT), dan ArcMap 10.x (TBX). Gunakan di
                        software manapun yang Anda suka.</p>
                </div>

                <!-- Feature 2 -->
                <div
                    class="p-8 rounded-2xl glass hover:bg-slate-800/50 transition duration-300 border-t border-cyan-500/20 text-center group">
                    <div
                        class="w-20 h-20 bg-cyan-500/10 rounded-2xl flex items-center justify-center mb-6 mx-auto group-hover:scale-110 transition">
                        <img src="/assets/img/icon_demnas.png" alt="DEMNAS Icon" class="w-12 h-12">
                    </div>
                    <h3 class="text-xl font-bold mb-3">DEMNAS & BATNAS</h3>
                    <p class="text-slate-400">Integrasi langsung ke server BIG untuk unduh data DEM Nasional dan
                        Batimetri Nasional resolusi tinggi.</p>
                </div>

                <!-- Feature 3 -->
