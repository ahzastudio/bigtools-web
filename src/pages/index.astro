                    class="p-8 rounded-2xl glass hover:bg-slate-800/50 transition duration-300 border-t border-purple-500/20 text-center group">
                    <div
                        class="w-20 h-20 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 mx-auto group-hover:scale-110 transition">
                        <img src="/assets/img/icon_login.png" alt="Login Icon" class="w-12 h-12">
