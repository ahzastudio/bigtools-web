                <h3 class="text-4xl font-black text-white mb-2">BIG DOWNLOADER TOOLBOX</h3>
                <p class="text-emerald-300 font-medium mb-12">Versi 2.0 • QGIS • ArcGIS Pro • ArcMap</p>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
                    <!-- QGIS -->
                    <a href="/assets/data/Toolbox BIG Downloader QGIS.zip" download
