                        <span class="text-xs text-slate-400">Versi 10.x (ZIP)</span>
                    </a>

                    <!-- Data Grid & Batas (Local) -->
                    <a href="/assets/data/Bahan Grid.zip" download
                        class="group flex flex-col items-center justify-center p-6 bg-slate-700 border border-slate-500/50 rounded-xl hover:bg-slate-600 hover:border-slate-400 hover:scale-105 transition duration-300">
                        <div class="w-12 h-12 mb-3 text-white">
                            <svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                                </path>
                            </svg>
                        </div>
                        <span class="font-bold text-lg">Bahan Grid</span>
                        <span class="text-xs text-slate-400">Grid Index & Batnas (Link 1)</span>
                    </a>

                    <!-- Data Batas (GDrive) -->
